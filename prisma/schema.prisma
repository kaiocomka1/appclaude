generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TipoLancamento {
  ENTRADA
  SAIDA
}

enum Escopo {
  PESSOAL
  EMPRESARIAL
}

enum FormaPagamento {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  DINHEIRO
  BOLETO
  PLATAFORMA
}

enum StatusLancamento {
  CONFIRMADO
  PREVISTO
  CANCELADO
}

enum OrigemLancamento {
  MANUAL
  FOTO
  RECORRENTE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Lancamento {
  id             String           @id @default(cuid())
  tipo           TipoLancamento
  escopo         Escopo
  categoriaId    String
  categoria      Categoria        @relation(fields: [categoriaId], references: [id])
  descricao      String
  valor          Decimal
  data           DateTime
  formaPagamento FormaPagamento
  cartaoId       String?
  cartao         Cartao?          @relation(fields: [cartaoId], references: [id])
  parcela        Int?
  totalParcelas  Int?
  grupoId        String?
  status         StatusLancamento @default(CONFIRMADO)
  origem         OrigemLancamento @default(MANUAL)
  anexoUrl       String?
  hashAnexo      String?
  criadoEm      DateTime         @default(now())
  atualizadoEm  DateTime         @updatedAt

  @@index([data])
  @@index([grupoId])
  @@index([status])
  @@index([escopo])
  @@index([hashAnexo])
}

model Cartao {
  id             String       @id @default(cuid())
  nome           String
  bandeira       String
  limite         Decimal
  diaFechamento  Int
  diaVencimento  Int
  ativo          Boolean      @default(true)
  lancamentos    Lancamento[]
  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt
}

model Categoria {
  id           String            @id @default(cuid())
  nome         String            @unique
  tipo         TipoLancamento
  deSistema    Boolean           @default(false)
  lancamentos  Lancamento[]
  regras       RegraDesignacao[]
  criadoEm    DateTime          @default(now())
  atualizadoEm DateTime         @updatedAt
}

model RegraDesignacao {
  id              String    @id @default(cuid())
  estabelecimento String    @unique
  escopo          Escopo
  categoriaId     String
  categoria       Categoria @relation(fields: [categoriaId], references: [id])
  atualizadoEm   DateTime  @updatedAt

  @@index([estabelecimento])
}

model Settings {
  id                String    @id @default("singleton")
  ultimoCheckDiario DateTime?
  criadoEm         DateTime  @default(now())
  atualizadoEm     DateTime  @updatedAt
}
